{
  "name": "@orbit/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./card": {
      "types": "./dist/repos/card.d.ts",
      "import": "./dist/repos/card.js"
    },
    "./deck": {
      "types": "./dist/repos/deck.d.ts",
      "import": "./dist/repos/deck.js"
    },
    "./note": {
      "types": "./dist/repos/note.d.ts",
      "import": "./dist/repos/note.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --exclude=\"dist/**\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@orbit/anki": "workspace:*",
    "@orbit/api": "workspace:*",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "@orbit/eslint-config": "workspace:*",
    "@types/node": "25.9.3",
    "eslint": "10.5.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
