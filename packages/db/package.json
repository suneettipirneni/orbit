{
  "name": "@orbit/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && rm -rf dist/migrations && cp -R src/migrations dist/migrations",
    "lint": "eslint .",
    "test": "vitest run --exclude=\"dist/**\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@orbit/anki": "workspace:*",
    "@orbit/api": "workspace:*",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "@orbit/eslint-config": "workspace:*",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.9.3",
    "better-sqlite3": "12.11.1",
    "eslint": "10.5.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "better-sqlite3": "12.11.1"
  }
}
