{
  "name": "@orbit/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo \"Skipping lint for generated shadcn UI package\"",
    "test": "vitest run --passWithNoTests --exclude=\"dist/**\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@fontsource-variable/geist": "5.2.9",
    "@tanstack/react-table": "8.21.3",
    "class-variance-authority": "0.7.1",
    "cmdk": "1.1.1",
    "cnfast": "0.0.6",
    "date-fns": "4.4.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "1.18.0",
    "next-themes": "0.4.6",
    "radix-ui": "1.6.0",
    "react-day-picker": "10.0.1",
    "react-hook-form": "7.79.0",
    "react-resizable-panels": "4.11.2",
    "recharts": "3.8.0",
    "shadcn": "4.11.0",
    "sonner": "2.0.7",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@orbit/eslint-config": "workspace:*",
    "@types/react": "19.2.17",
    "eslint": "10.5.0",
    "react": "19.3.0-canary-247fbb45-20260622",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "react": ">=19.0.0 || 19.3.0-canary-247fbb45-20260622",
    "react-dom": ">=19.0.0 || 19.3.0-canary-247fbb45-20260622",
    "react-hook-form": ">=7.0.0"
  }
}
