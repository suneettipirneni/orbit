{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@orbit/api": ["../../packages/api/src/index.ts"],
      "@orbit/api/*": ["../../packages/api/src/*"],
      "@orbit/ui": ["../../packages/ui/src/index.ts"],
      "@orbit/ui/*": ["../../packages/ui/src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src", "../../packages/api/src", "../../packages/ui/src"]
}
