{
  "name": "@orbit/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "build": "pnpm run rebuild:native && react-router typegen && react-router build && electron-vite build --config electron.vite.config.ts",
    "dev": "node scripts/dev.mjs",
    "lint": "react-router typegen && eslint .",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "start": "electron-vite preview --config electron.vite.config.ts",
    "test": "env ELECTRON_RUN_AS_NODE=1 electron ./node_modules/vitest/vitest.mjs run --passWithNoTests --exclude=\"dist/**\" --exclude=\"e2e/**\"",
    "test:e2e": "playwright test",
    "typecheck": "react-router typegen && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@orbit/anki": "workspace:*",
    "@orbit/types": "workspace:*",
    "@orbit/ui": "workspace:*",
    "@pierre/trees": "1.0.0-beta.4",
    "@powersync/drizzle-driver": "0.7.3",
    "@powersync/react": "1.10.0",
    "@powersync/web": "1.38.4",
    "@react-router/fs-routes": "8.0.1",
    "@react-router/node": "8.0.1",
    "@tanstack/react-table": "8.21.3",
    "better-sqlite3": "12.11.1",
    "drizzle-orm": "0.45.2",
    "electron": "42.4.0",
    "isbot": "^5.1.36",
    "lucide-react": "1.18.0",
    "react": "19.3.0-canary-247fbb45-20260622",
    "react-dom": "19.3.0-canary-247fbb45-20260622",
    "react-hook-form": "7.79.0",
    "react-router": "8.0.1",
    "tailwindcss": "4.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@electron/rebuild": "4.0.4",
    "@orbit/eslint-config": "workspace:*",
    "@playwright/test": "1.61.0",
    "@react-router/dev": "8.0.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "4.3.1",
    "@types/babel__core": "7.20.5",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "electron-builder": "26.15.3",
    "electron-vite": "6.0.0-beta.1",
    "eslint": "10.5.0",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
