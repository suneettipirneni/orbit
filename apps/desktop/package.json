{
  "name": "@orbit/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint .",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "start": "electron .",
    "test": "vitest run --passWithNoTests --exclude=\"dist/**\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@orbit/server": "workspace:*",
    "electron": "42.4.0"
  },
  "devDependencies": {
    "@orbit/eslint-config": "workspace:*",
    "@electron/rebuild": "4.0.4",
    "@types/node": "25.9.3",
    "eslint": "10.5.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
