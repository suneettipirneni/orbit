{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": ".",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "@/*": ["./src/renderer/*"]
    },
    "types": ["node", "vite/client", "react/canary", "react-dom/canary"]
  },
  "include": [".react-router/types/**/*", "e2e/**/*.ts", "playwright.config.ts", "src"]
}
