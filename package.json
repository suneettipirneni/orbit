{
  "name": "orbit",
  "version": "0.1.0",
  "private": true,
  "description": "Orbit is a modern Electron and SQLite spaced repetition app.",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@orbit/desktop",
    "dev:desktop": "turbo run dev --filter=@orbit/desktop",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@orbit/eslint-config": "workspace:*",
    "oxfmt": "0.55.0",
    "turbo": "2.9.18",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.7.0"
}
